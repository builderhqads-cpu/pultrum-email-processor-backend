# ==========================================================================
# Pultrum mail processor — environment template
# Copy to .env and fill in. NEVER commit the real .env (it holds secrets).
# ==========================================================================

# App
NODE_ENV=development
PORT=3000
# Comma-separated allowed CORS origins (frontend URL). Empty = reflect any.
CORS_ORIGINS=
# Code required to self-register an account (/auth/register). Empty = disabled.
REGISTRATION_CODE=

# Database
# Local/docker-compose dev uses the bundled Postgres on port 5433.
# In docker-compose.prod.yml this is overridden to point at the "postgres" service.
POSTGRES_DB=pultrum_mail_processor
POSTGRES_USER=pultrum
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://pultrum:change-me@localhost:5433/pultrum_mail_processor?schema=public

# Redis / BullMQ
# On a managed host (Easypanel) set REDIS_HOST to the service name and provide
# the generated password. Leave password empty for a local passwordless Redis.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# REDIS_USERNAME=   # only if your Redis uses an ACL user other than "default"

# Seed: admin user (prisma/seed.ts). Set real values before seeding in production.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# Seed mailboxes (optional overrides, used only by prisma/seed.ts)
OPEN_TRANSPORT_MAILBOX=planning@pultrum-rijssen.nl
STUK_GOED_MAILBOX=stukgoed@pultrum-rijssen.nl
TEST_MAILBOX_EMAIL=

# Mail provider: graph | imap
MAIL_PROVIDER=graph

# Mailbox auto-sync interval (the on/off toggle lives in the SystemSettings
# table, managed from the frontend Automation tab — not here).
MAILBOX_SYNC_INTERVAL_SECONDS=60

# Microsoft Graph OAuth (delegated)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# "consumers" for personal accounts, or the company tenant ID for org mailboxes.
MS_TENANT_ID=consumers
# Must match the redirect URI registered in the Azure app.
MS_REDIRECT_URI=http://localhost:3000/auth/callback
FRONTEND_SETTINGS_URL=http://localhost:3001/en/settings
GRAPH_CONNECTED_MAILBOX_DEPARTMENT=OPEN_TRANSPORT

# IMAP (only used when MAIL_PROVIDER=imap)
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_SECURE=true
# IMAP_USER=
# IMAP_PASSWORD=
# IMAP_AUTH_TYPE=password
# IMAP_AUTO_CREATE_MAILBOX=true
# IMAP_MAILBOX_DEPARTMENT=OPEN_TRANSPORT

# AI (extraction / reply / classification). Point AI_API_BASE_URL at your
# router; the self-loopback below uses the built-in OpenRouter test routes.
AI_API_BASE_URL=http://localhost:3000
AI_EXTRACTION_API_URL=/ai-test/extract-transport-order
AI_REPLY_API_URL=/ai-test/generate-missing-info-reply
AI_CLASSIFICATION_API_URL=/ai-test/classify-email
# New flow: route that processes the email from the .eml (classify + orders).
AI_EML_PROCESS_API_URL=/eml-process
# Consolidated missing-info reply (one e-mail per batch, grouped by order).
# Empty = reuse AI_REPLY_API_URL; if no route answers, a built-in template is used.
# AI_CONSOLIDATED_REPLY_API_URL=/generate-missing-info-reply
AUTO_AI_CLASSIFICATION_ENABLED=true
AI_EXTRACTION_TIMEOUT_MS=120000
AI_REPLY_TIMEOUT_MS=120000

# New flow: send only the .eml to the AI; it classifies + returns the order(s),
# and we just store them. Legacy pipeline stays in place but is bypassed.
AI_EMAIL_ANALYSIS_ENABLED=true

# Batch split: our own AI fallback (OpenRouter) for unmapped clients. Per-client
# deterministic rules run first. OFF by default. Set true to test AI detection.
# Per-client rules engine (Derix etc.). OFF while the AI handles everything from
# the .eml. Set true to re-enable the deterministic client profiles.
CLIENT_PROFILE_ENABLED=false

BATCH_SPLIT_AI_ENABLED=false
# BATCH_SPLIT_MODEL=openai/gpt-4o-mini
# Batch orders are always filled (deterministic + AI); this only auto-enqueues
# their XML/reply jobs. OFF avoids mass auto-replies/XML while testing.
BATCH_ENQUEUE_JOBS_ENABLED=false

# OpenRouter (AI + OCR)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT_MS=120000

# Creative Gears (carrier delivery target). Empty = mock mode.
CREATIVE_GEARS_API_URL=
CREATIVE_GEARS_USERNAME=
CREATIVE_GEARS_PASSWORD=

# OCR
# Max attachment size (MB) to download + extract from Graph. Default 15.
ATTACHMENT_MAX_MB=15

OCR_ENABLED=true
# Image/computer-vision OCR, gated separately (photos cost ~4x tokens). OFF by
# default: images are attached but not processed. Set true to re-enable vision.
IMAGE_OCR_ENABLED=false
# openrouter | azure-document-intelligence | google-document-ai | tesseract
OCR_PROVIDER=openrouter
OCR_OPENROUTER_MODEL=openai/gpt-4o-mini

# Reply / outbound email
EMAIL_SEND_PROVIDER=graph
